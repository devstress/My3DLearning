        "definition": "label_values(eip_messages_dead_lettered_total, eip_message_type)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "message_type",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(eip_messages_dead_lettered_total, eip_message_type)", "refId": "VariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
