        "includeAll": true,
        "multi": true,
        "name": "message_type",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(eip_messages_received_total, eip_message_type)", "refId": "VariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
